E_370/final)\"}\n!6 = !{i32 0, %struct.RaytracingAccelerationStructure* @\"\\01?gScene@@3URaytracingAccelerationStructure@@A\", !\"gScene\", i32 0, i32 0, i32 1, i32 16, i32 0, !7}\n!11 = !{i32 1, void ()* @\"\\01?RayGen@@YAXXZ\", !12, void (%struct.Payload*)* @\"\\01?simple_miss@@YAXUPayload@@@Z\", !15, void (%struct.Payload*, %struct.BuiltInTriangleIntersectionAttributes*)* @\"\\01?simple_hit@@YAXUPayload@@UBuiltInTriangleIntersectionAttributes@@@Z\", !17}\n!24 = !{void (%struct.Payload*, %struct.BuiltInTriangleIntersectionAttributes*)* @\"\\01?simple_hit@@YAXUPayload@@UBuiltInTriangleIntersectionAttributes@@@Z\", !\"\\01?simple_hit@@YAXUPayload@@UBuiltInTriangleIntersectionAttributes@@@Z\", null, null, !25}\n!31 = !{!\"Simple C/C++ TBAA\"}",
