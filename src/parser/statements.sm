================================================================================
OBJECT from realistic DXIL
================================================================================

OBJECT csobj
; Not compiling, but contains some realistic input
; ModuleID = '0x00000000000000000000000000000000'
target datalayout = "e-m:e-p:32:32-i1:32-i8:8-i16:32-i32:32-i64:64-f16:32-f32:32-f64:64-n8:16:32:64"
target triple = "dxil-ms-dx"

%struct.RaytracingAccelerationStructure = type { i32 }
%"class.RWBuffer<float>" = type { float }
%struct.Payload = type { float, [38 x float] }
%dx.types.Handle = type { i8* }
%struct.BuiltInTriangleIntersectionAttributes = type { <2 x float> }

@"\01?gScene@@3URaytracingAccelerationStructure@@A" = external constant %struct.RaytracingAccelerationStructure, align 4
@"\01?gOutput@@3V?$RWBuffer@M@@A" = external constant %"class.RWBuffer<float>", align 4

; Function Attrs: nounwind
define void @"\01?RayGen@@YAXXZ"() #0 {
  %1 = load %struct.RaytracingAccelerationStructure, %struct.RaytracingAccelerationStructure* @"\01?gScene@@3URaytracingAccelerationStructure@@A", align 4
  %2 = load %"class.RWBuffer<float>", %"class.RWBuffer<float>"* @"\01?gOutput@@3V?$RWBuffer@M@@A", align 4
  %3 = alloca %struct.Payload, align 4
  %4 = call i32 @dx.op.dispatchRaysDimensions.i32(i32 146, i8 0)
  call void @dx.op.traceRay.struct.Payload(i32 157, %dx.types.Handle %17, i32 0, i32 255, i32 0, i32 0, i32 0, float %15, float %16, float 0.000000e+00, float 0x3F1A36E2E0000000, float 0.000000e+00, float 0.000000e+00, float 1.000000e+00, float 0x47D2CED320000000, %struct.Payload* nonnull %3)
  br label %18
}

; Function Attrs: nounwind memory(read)
declare %dx.types.Handle @"dx.op.createHandleForLib.class.RWBuffer<float>"(i32, %"class.RWBuffer<float>") #2

attributes #0 = { nounwind }
attributes #1 = { nounwind memory(none) }
attributes #2 = { nounwind memory(read) }

!llvm.ident = !{!0}
!dx.version = !{!1}
!dx.valver = !{!2}
!dx.shaderModel = !{!3}
!dx.resources = !{!4}
!dx.typeAnnotations = !{!11}
!dx.entryPoints = !{!19, !21, !24, !26}

!0 = !{!"clang version 3.7 (tags/RELEASE_370/final)"}
!6 = !{i32 0, %struct.RaytracingAccelerationStructure* @"\01?gScene@@3URaytracingAccelerationStructure@@A", !"gScene", i32 0, i32 0, i32 1, i32 16, i32 0, !7}
!11 = !{i32 1, void ()* @"\01?RayGen@@YAXXZ", !12, void (%struct.Payload*)* @"\01?simple_miss@@YAXUPayload@@@Z", !15, void (%struct.Payload*, %struct.BuiltInTriangleIntersectionAttributes*)* @"\01?simple_hit@@YAXUPayload@@UBuiltInTriangleIntersectionAttributes@@@Z", !17}
!24 = !{void (%struct.Payload*, %struct.BuiltInTriangleIntersectionAttributes*)* @"\01?simple_hit@@YAXUPayload@@UBuiltInTriangleIntersectionAttributes@@@Z", !"\01?simple_hit@@YAXUPayload@@UBuiltInTriangleIntersectionAttributes@@@Z", null, null, !25}
!31 = !{!"Simple C/C++ TBAA"}
END

--------------------------------------------------------------------------------

